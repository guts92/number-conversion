int main()
{
	int a, b, c, tap;
	printf("输入三个整数；");
	scanf("%d%d%d", &a, &b, &c);
	if (a < b)
	{
		tap = a;
		a = b;
		b = tap;
	}
	if (a < c)
	{
		tap = a;
		a = c;
		c = tap;
	}
